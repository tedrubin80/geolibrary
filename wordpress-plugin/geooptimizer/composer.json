{
    "name": "geooptimizer/wordpress-plugin",
    "description": "WordPress plugin for GeoOptimizer",
    "type": "wordpress-plugin",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "geooptimizer/php-geo-optimizer": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../",
            "options": {
                "symlink": false
            }
        }
    ],
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
