#!/usr/bin/env php
<?php

declare(strict_types=1);

$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../vendor/autoload.php',
];

foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require $autoloadPath;
        break;
    }
}

$host = getenv('GEO_API_HOST') ?: '127.0.0.1';
$port = (int) (getenv('GEO_API_PORT') ?: 8080);
$router = __DIR__ . '/../public/api/index.php';

fwrite(STDOUT, "GeoOptimizer API listening on http://{$host}:{$port}\n");
fwrite(STDOUT, "Set GEO_API_KEY to require authentication on protected routes.\n");

passthru(sprintf(
    'php -S %s:%d -t %s %s',
    escapeshellarg($host),
    $port,
    escapeshellarg(dirname($router)),
    escapeshellarg($router)
));
