{
    "name": "geooptimizer/geo-optimizer",
    "description": "The comprehensive PHP library for Generative Engine Optimization (GEO) - optimizing websites for AI-powered search engines like ChatGPT, Claude, Perplexity, and Google AI Overviews",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "geo",
        "generative-engine-optimization",
        "ai-search",
        "seo",
        "llm",
        "chatgpt",
        "claude",
        "perplexity",
        "google-ai",
        "schema-org",
        "structured-data",
        "llms-txt",
        "content-optimization",
        "citation-tracking"
    ],
    "homepage": "https://github.com/tedrubin80/geolibrary",
    "authors": [
        {
            "name": "Ted Rubin",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/tedrubin80/geolibrary/issues",
        "source": "https://github.com/tedrubin80/geolibrary"
    },
    "require": {
        "php": ">=8.0",
        "spatie/schema-org": "^3.0",
        "twig/twig": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/console": "^5.0|^6.0|^7.0",
        "symfony/cache": "^5.0|^6.0|^7.0",
        "psr/log": "^1.0|^2.0|^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "mockery/mockery": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "GEOOptimizer\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GEOOptimizer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "cs-fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse --level=8"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "2.0-dev"
        }
    }
}
