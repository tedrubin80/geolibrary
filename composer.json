{
    "name": "geooptimizer/php-geo-optimizer",
    "description": "The first comprehensive PHP library for Generative Engine Optimization (GEO) - optimizing websites for AI-powered search engines",
    "type": "library",
    "license": "MIT",
    "keywords": ["seo", "geo", "ai-search", "optimization", "llm", "generative-engine-optimization"],
    "homepage": "https://geooptimizer.dev",
    "support": {
        "issues": "https://github.com/tedrubin80/geolibrary/issues",
        "source": "https://github.com/tedrubin80/geolibrary"
    },
    "authors": [
        {
            "name": "GeoOptimizer",
            "homepage": "https://geooptimizer.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=7.4",
        "spatie/schema-org": "^3.0",
        "twig/twig": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/console": "^5.0|^6.0",
        "symfony/cache": "^5.0|^6.0",
        "psr/log": "^1.0|^2.0|^3.0"
    },
    "require-dev": {
        "brain/monkey": "^2.6",
        "friendsofphp/php-cs-fixer": "^3.0",
        "mockery/mockery": "^1.0",
        "php-stubs/wordpress-stubs": "^6.0",
        "phpstan/phpstan": "^1.0",
        "phpunit/phpunit": "^9.0|^10.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "GEOOptimizer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GEOOptimizer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "cs-fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse",
        "build": "php tools/build.php",
        "publish-verify": "php tools/publish-verify.php"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["bin/geo-optimizer", "bin/geo-api"],
    "suggest": {
        "laravel/framework": "Required to use the Laravel service provider and facade.",
        "symfony/framework-bundle": "Required to use the Symfony bundle integration."
    },
    "archive": {
        "exclude": [
            "tests",
            "docs",
            "dist",
            "coverage",
            "wordpress-plugin",
            "public",
            "tools",
            ".github",
            "phpunit.xml",
            "phpstan.neon.dist",
            ".phpunit.result.cache"
        ]
    }
}
