# GEO Testing Platform - Environment Variables

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/geo_testing
# For SQLite (development): sqlite:///./geo_testing.db

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=mistral:7b-instruct
OLLAMA_VALIDATION_MODEL=gemma2:9b

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Testing Configuration
MAX_CONCURRENT_TESTS=5
DEFAULT_ITERATIONS=10
ENABLE_COST_TRACKING=false  # No cost with Ollama!

# Domain
DOMAIN=geooptimizer.dev
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/geo-testing.log
